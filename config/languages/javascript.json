{
  "name": "JavaScript/TypeScript",
  "slice_type": "CodeBlock",
  "priority": 100,
  "description": "JavaScript/TypeScript 代码语法检测配置",
  "file_extensions": [".js", ".jsx", ".ts", ".tsx", ".mjs"],
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "contains", "pattern": "function "},
        {"pattern_type": "contains", "pattern": "const "},
        {"pattern_type": "contains", "pattern": "let "},
        {"pattern_type": "contains", "pattern": "var "},
        {"pattern_type": "contains", "pattern": "=>"},
        {"pattern_type": "contains", "pattern": "console.log("},
        {"pattern_type": "contains", "pattern": "import "},
        {"pattern_type": "contains", "pattern": "export "},
        {"pattern_type": "contains", "pattern": "async "},
        {"pattern_type": "contains", "pattern": "await "},
        {"pattern_type": "contains", "pattern": "class "},
        {"pattern_type": "contains", "pattern": "extends "},
        {"pattern_type": "contains", "pattern": "interface "},
        {"pattern_type": "contains", "pattern": "type "},
        {"pattern_type": "contains", "pattern": "Promise<"},
        {"pattern_type": "contains", "pattern": "React."},
        {"pattern_type": "contains", "pattern": "ReactDOM."}
      ]
    }
  ]
}
