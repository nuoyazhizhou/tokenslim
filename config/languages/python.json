{
  "name": "Python",
  "slice_type": "CodeBlock",
  "priority": 100,
  "description": "Python 代码语法检测配置",
  "file_extensions": [".py", ".pyw", ".pyi"],
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "contains", "pattern": "def "},
        {"pattern_type": "contains", "pattern": "class "},
        {"pattern_type": "contains", "pattern": "import "},
        {"pattern_type": "contains", "pattern": "from "},
        {"pattern_type": "contains", "pattern": "if __name__"},
        {"pattern_type": "contains", "pattern": "print("},
        {"pattern_type": "contains", "pattern": "return "},
        {"pattern_type": "contains", "pattern": "for "},
        {"pattern_type": "contains", "pattern": "while "},
        {"pattern_type": "contains", "pattern": "try:"},
        {"pattern_type": "contains", "pattern": "except"},
        {"pattern_type": "contains", "pattern": "with "},
        {"pattern_type": "contains", "pattern": "lambda "},
        {"pattern_type": "contains", "pattern": "yield "},
        {"pattern_type": "contains", "pattern": "async "},
        {"pattern_type": "contains", "pattern": "await "}
      ]
    }
  ]
}
