{
  "name": "Scala",
  "slice_type": "CodeBlock",
  "priority": 100,
  "description": "Scala 代码语法检测配置",
  "file_extensions": [".scala", ".sbt"],
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "contains", "pattern": "object "},
        {"pattern_type": "contains", "pattern": "def "},
        {"pattern_type": "contains", "pattern": "val "},
        {"pattern_type": "contains", "pattern": "var "},
        {"pattern_type": "contains", "pattern": "class "},
        {"pattern_type": "contains", "pattern": "trait "},
        {"pattern_type": "contains", "pattern": "extends "},
        {"pattern_type": "contains", "pattern": "with "},
        {"pattern_type": "contains", "pattern": "case class"},
        {"pattern_type": "contains", "pattern": "println("},
        {"pattern_type": "contains", "pattern": "match {"},
        {"pattern_type": "contains", "pattern": "=>" },
        {"pattern_type": "contains", "pattern": "List["},
        {"pattern_type": "contains", "pattern": "Option["},
        {"pattern_type": "contains", "pattern": "Future["},
        {"pattern_type": "contains", "pattern": "implicit "}
      ]
    }
  ]
}
