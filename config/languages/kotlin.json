{
  "name": "Kotlin",
  "slice_type": "CodeBlock",
  "priority": 100,
  "description": "Kotlin 代码语法检测配置",
  "file_extensions": [".kt", ".kts"],
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "contains", "pattern": "fun "},
        {"pattern_type": "contains", "pattern": "fun main("},
        {"pattern_type": "contains", "pattern": "class "},
        {"pattern_type": "contains", "pattern": "object "},
        {"pattern_type": "contains", "pattern": "interface "},
        {"pattern_type": "contains", "pattern": "val "},
        {"pattern_type": "contains", "pattern": "var "},
        {"pattern_type": "contains", "pattern": "println("},
        {"pattern_type": "contains", "pattern": "override "},
        {"pattern_type": "contains", "pattern": "@JvmStatic"},
        {"pattern_type": "contains", "pattern": "@Composable"},
        {"pattern_type": "contains", "pattern": "suspend "},
        {"pattern_type": "contains", "pattern": "coroutine"},
        {"pattern_type": "contains", "pattern": "data class"},
        {"pattern_type": "contains", "pattern": "sealed class"},
        {"pattern_type": "contains", "pattern": "when ("},
        {"pattern_type": "contains", "pattern": "?. "}
      ]
    }
  ]
}
