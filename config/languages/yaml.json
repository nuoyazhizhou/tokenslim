{
  "name": "YAML",
  "slice_type": "CodeBlock",
  "priority": 100,
  "description": "YAML 配置文件语法检测配置",
  "file_extensions": [".yaml", ".yml"],
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "contains", "pattern": "---"},
        {"pattern_type": "contains", "pattern": "..."},
        {"pattern_type": "contains", "pattern": "  "},
        {"pattern_type": "contains", "pattern": "- "},
        {"pattern_type": "contains", "pattern": ": "},
        {"pattern_type": "contains", "pattern": "#"},
        {"pattern_type": "contains", "pattern": "&"},
        {"pattern_type": "contains", "pattern": "*"},
        {"pattern_type": "contains", "pattern": "<<"},
        {"pattern_type": "contains", "pattern": "|"},
        {"pattern_type": "contains", "pattern": ">"},
        {"pattern_type": "contains", "pattern": "%YAML"},
        {"pattern_type": "contains", "pattern": "%TAG"},
        {"pattern_type": "contains", "pattern": "!!"},
        {"pattern_type": "contains", "pattern": "null"},
        {"pattern_type": "contains", "pattern": "~"},
        {"pattern_type": "contains", "pattern": "true"},
        {"pattern_type": "contains", "pattern": "false"}
      ]
    }
  ]
}
