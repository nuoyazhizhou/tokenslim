{
  "name": "GCC Compile Options",
  "category": "compiler_flags",
  "priority": 100,
  "patterns": {
    "optimization": ["-O0", "-O1", "-O2", "-O3", "-Os", "-Ofast", "-Og"],
    "warning": ["-Wall", "-Wextra", "-Werror", "-Wpedantic", "-w"],
    "debug": ["-g", "-g0", "-g1", "-g2", "-g3", "-ggdb"],
    "standard": ["-std=c99", "-std=c11", "-std=c17", "-std=c++11", "-std=c++14", "-std=c++17", "-std=c++20"],
    "position_independent": ["-fPIC", "-fPIE", "-fpic", "-fpie"],
    "reentrant": ["-D_REENTRANT", "-D_THREAD_SAFE"],
    "common_defines": [
      "DEBUG", "DEBUG_LEVEL", "NDEBUG", 
      "HAVE_CONFIG_H", "PACKAGE_VERSION",
      "USE_SSL", "HAVE_PTHREAD"
    ]
  }
}
