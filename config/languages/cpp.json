{
  "name": "C/C++",
  "slice_type": "CodeBlock",
  "priority": 100,
  "description": "C/C++ 代码语法检测配置",
  "file_extensions": [".c", ".cpp", ".cc", ".cxx", ".h", ".hpp", ".hxx"],
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "contains", "pattern": "#include"},
        {"pattern_type": "contains", "pattern": "int main("},
        {"pattern_type": "contains", "pattern": "std::"},
        {"pattern_type": "contains", "pattern": "cout <<"},
        {"pattern_type": "contains", "pattern": "cin >>"},
        {"pattern_type": "contains", "pattern": "printf("},
        {"pattern_type": "contains", "pattern": "scanf("},
        {"pattern_type": "contains", "pattern": "malloc("},
        {"pattern_type": "contains", "pattern": "free("},
        {"pattern_type": "contains", "pattern": "namespace "},
        {"pattern_type": "contains", "pattern": "template<typename"},
        {"pattern_type": "contains", "pattern": "class "},
        {"pattern_type": "contains", "pattern": "struct "},
        {"pattern_type": "contains", "pattern": "virtual "},
        {"pattern_type": "contains", "pattern": "override"}
      ]
    }
  ]
}
