{
    "name": "git_diff",
    "description": "Git diff 输出脱水",
    "priority": 200,
    "enabled": true,
    "detect": {
        "rules": [
            {
                "type": "any",
                "patterns": []
            }
        ],
        "min_match_ratio": 0.05
    },
    "compress": {
        "token_prefix": "$GIT_DI"
    },
    "keep_signals": [
        "diff --git行（文件差异标记）",
        "--- a/行（旧文件路径）",
        "+++ b/行（新文件路径）",
        "HUNK_HEADER行（块头部）",
        "index行（文件索引信息）"
    ],
    "compress_targets": [
        "非header行（如上下文内容）",
        "文件路径简化（通过token_prefix）"
    ],
    "design_intent": "Git diff脱水：保留diff header和hunk header，折叠非关键行，压缩文件路径。"
}
