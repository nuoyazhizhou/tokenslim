{
    "name": "syslog",
    "description": "系统日志脱水",
    "priority": 130,
    "enabled": true,
    "detect": {
        "rules": [
            {
                "type": "regex",
                "pattern": "^[A-Z][a-z]{2}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2}"
            }
        ],
        "min_match_ratio": 0.2
    },
    "compress": {
        "token_prefix": "$SYSLOG",
        "dedup": {
            "enabled": true,
            "threshold": 1
        }
    },
    "keep_signals": [
        "时间戳（月 日 时:分:秒）",
        "消息内容（msg）",
        "PID（进程ID，可选）",
        "非syslog格式的行（原样保留）"
    ],
    "compress_targets": [
        "主机名（替换为$SYS格式中的字典令牌）",
        "进程名（替换为$SYS格式中的字典令牌）"
    ],
    "design_intent": "系统日志脱水：保留时间戳和消息内容，折叠主机名和进程名为字典令牌，压缩重复标识。"
}
