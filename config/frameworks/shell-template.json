{
  "name": "Shell Templates",
  "slice_type": "TemplateBlock",
  "priority": 100,
  "description": "Shell 脚本模板语法检测配置",
  "rules": [
    {
      "type": "any",
      "patterns": [
        {"pattern_type": "paired_delimiters", "pattern": "${", "end_delimiter": "}"},
        {"pattern_type": "paired_delimiters", "pattern": "$(", "end_delimiter": ")"},
        {"pattern_type": "paired_delimiters", "pattern": "`", "end_delimiter": "`"},
        {"pattern_type": "paired_delimiters", "pattern": "[((", "end_delimiter": "))"}
      ]
    }
  ]
}
