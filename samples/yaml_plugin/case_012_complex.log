application:
  name: complex-app
  version: 2.0.0
  environment: production
server:
  port: 443
  host: api.example.com
  tls:
    enabled: true
    min_version: TLSv1.2
    certificates:
      - cert.pem
      - key.pem
database:
  primary:
    host: db-primary.example.com
    port: 5432
    database: appdb
    credentials:
      username: appuser
      password: ${DB_PASSWORD}
  replica:
    host: db-replica.example.com
    port: 5432
features:
  authentication:
    enabled: true
    providers:
      - oauth2
      - jwt
  rate_limiting:
    enabled: true
    requests_per_minute: 100
logging:
  level: warn
  format: structured
  destinations:
    - type: file
      path: /var/log/app.log
    - type: cloudwatch
      region: us-east-1
