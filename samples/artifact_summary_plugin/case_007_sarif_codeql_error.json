{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "semanticVersion": "2.17.1",
          "rules": [
            {"id": "js/sql-injection", "shortDescription": {"text": "Database query built from user-controlled sources"}},
            {"id": "js/path-injection", "shortDescription": {"text": "Uncontrolled data used in path expression"}}
          ]
        }
      },
      "results": [
        {
          "ruleId": "js/sql-injection",
          "level": "error",
          "message": {"text": "This query depends on a user-provided value and may be vulnerable to SQL injection."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "src/server/reporting/query_builder.ts"}, "region": {"startLine": 184, "startColumn": 19}}}]
        },
        {
          "ruleId": "js/path-injection",
          "level": "warning",
          "message": {"text": "This filesystem path includes request parameter exportName without normalization."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "src/server/export/export_controller.ts"}, "region": {"startLine": 77, "startColumn": 27}}}]
        },
        {
          "ruleId": "js/sql-injection",
          "level": "error",
          "message": {"text": "String concatenation reaches db.raw in analytics segment lookup."},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "src/server/analytics/segments.ts"}, "region": {"startLine": 231, "startColumn": 12}}}]
        }
      ]
    }
  ]
}
