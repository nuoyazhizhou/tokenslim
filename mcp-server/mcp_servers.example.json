{
  "$schema": "https://modelcontextprotocol.io/mcp-config.schema.json",
  "_comment": "TokenSlim MCP Server 配置模板 / Configuration template",
  "_usage": [
    "复制本文件到你的 Agent 配置目录，并将路径替换为实际本地路径。",
    "Copy this file to your agent's config directory and replace paths with your actual local paths.",
    "",
    "Claude Code / Claude Desktop:  ~/.claude/claude_desktop_config.json  or  .mcp.json",
    "Cursor:                        .cursor/mcp.json",
    "Windsurf:                      ~/.codeium/windsurf/mcp_config.json",
    "Qoder (project):               .qoder/mcp_servers.json",
    "Qoder (global):                ~/.qoder/mcp_servers.json",
    "OpenCode:                      .opencode/mcp.json"
  ],

  "mcpServers": {
    "tokenslim": {
      "command": "node",
      "args": ["/path/to/mcp-server/dist/index.js"],
      "env": {
        "TOKENSLIM_CLI_PATH": "",
        "RUST_LOG": "info"
      }
    }
  },

  "_alternatives": {
    "npx_no_install": {
      "_comment": "通过 npx 运行，无需本地安装（发布后可用）/ Run via npx, no local install needed (after npm publish)",
      "mcpServers": {
        "tokenslim": {
          "command": "npx",
          "args": ["-y", "@tokenslim/mcp-server"]
        }
      }
    },
    "global_install": {
      "_comment": "全局安装后直接运行 / Run after global install",
      "mcpServers": {
        "tokenslim": {
          "command": "tokenslim-mcp-server",
          "args": []
        }
      }
    }
  }
}
