{
  "name": "tokenslim-vscode",
  "displayName": "TokenSlim",
  "description": "AI Input Decompression Engine for VS Code",
  "version": "0.1.0",
  "publisher": "tokenslim",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokenslim.compressCurrentFile",
        "title": "TokenSlim: Compress Current File"
      },
      {
        "command": "tokenslim.compressSelection",
        "title": "TokenSlim: Compress Selection"
      },
      {
        "command": "tokenslim.restartServer",
        "title": "TokenSlim: Restart Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}