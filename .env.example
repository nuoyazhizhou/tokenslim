# =============================================================================
# TokenSlim 本地环境变量模板
# =============================================================================
# 用法：
#   1. 复制本文件为 `.env`
#   2. 填入你本地真实值（密钥只填一次，绝不提交）
#   3. .env 已在 .gitignore 排除，不会被 git 跟踪
#
# 优先级：系统环境变量 > .env > 脚本默认值
# =============================================================================


# -----------------------------------------------------------------------------
# TokenSlim 行为配置
# -----------------------------------------------------------------------------

# 日志级别：trace / debug / info / warn / error
# 控制 tracing 输出。debug 可见 plugin 路由、dictionary、ROI 决策等。
RUST_LOG=info

# TokenSlim 自定义日志通道（可选，覆盖 RUST_LOG 中以 tokenslim 开头的 target）
# 留空表示继承 RUST_LOG
TOKENSLIM_LOG=


# -----------------------------------------------------------------------------
# LLM 审计（可选）
# -----------------------------------------------------------------------------
# 用于 `audit_*.py --llm-audit` 系列脚本。三个 LLM 审计脚本共享同一份配置。
# 兼容 OpenAI Chat Completions 协议，可以指向任何 OpenAI-compatible 服务
# （OpenAI、Azure OpenAI、本地 vLLM / Ollama / LM Studio 等）。
#
# 不填这些变量时，--llm-audit 会降级为 lint-only 模式（不会调用 LLM）。

# LLM Provider Base URL（OpenAI-compatible chat completions）
# 默认：https://api.openai.com/v1
# 常见替代：
#   Azure OpenAI:     https://<resource>.openai.azure.com/openai/deployments/<dep>
#   本地 vLLM:        http://localhost:8000/v1
#   LM Studio:        http://localhost:1234/v1
#   Ollama (openai):  http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM API Key（必需；不要 commit 到 git）
# 也可用 LLM_API_KEY 作为别名
OPENAI_API_KEY=sk-your-api-key-here

# LLM 模型名（与 provider 配套）
# OpenAI 示例：gpt-4o / gpt-4o-mini / gpt-4-turbo
# 本地示例：meta-llama/Llama-3-8B-Instruct / qwen2.5-7b-instruct
OPENAI_MODEL=gpt-4o-mini

# HTTP 请求超时（秒），默认 60
OPENAI_TIMEOUT=60

# 采样温度，0 = 确定性，1 = 创造性。审计场景建议 0
OPENAI_TEMPERATURE=0


# -----------------------------------------------------------------------------
# Case Sidecar 填充（可选）
# -----------------------------------------------------------------------------

# 在 fill_case_sidecars.py 时输出原始调试信息
# 0 = 关闭（默认），1 = 开启
FILL_DEBUG_RAW=0
